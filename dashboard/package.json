{
  "name": "librarian-dashboard",
  "version": "1.0.0",
  "type": "module",
  "description": "Operational dashboard for Librarian evidence retrieval engine",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:production": "tsc && vite build --mode production",
    "build:staging": "tsc && vite build --mode staging",
    "preview": "vite preview",
    "generate-types": "openapi-typescript http://localhost:8000/api/openapi.json -o src/types/api.d.ts",
    "validate-contract": "openapi-typescript http://localhost:8000/api/openapi.json -o src/types/api.d.ts && npm run build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "axios": "^1.6.7",
    "date-fns": "^3.3.1",
    "react-hot-toast": "^2.4.1",
    "leaflet": "^1.9.4",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/leaflet": "^1.9.8",
    "@vitejs/plugin-react": "^4.2.1",
    "openapi-typescript": "^6.7.4",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  }
}
