# Librarian Environment Configuration
#
# Copy this file to .env and configure for your environment.
# All settings have sensible defaults for development/testing.
#
# Production deployments should always use strong passwords.

# =============================================================================
# PostgreSQL Configuration
# =============================================================================

# Database name
POSTGRES_DB=librarian

# Database user
POSTGRES_USER=librarian

# Database password (CHANGE IN PRODUCTION)
POSTGRES_PASSWORD=librarian

# PostgreSQL port
POSTGRES_PORT=5432

# =============================================================================
# API Configuration
# =============================================================================

# API server host port (external mapping to internal port 8000)
API_HOST_PORT=8001

# =============================================================================
# Library Configuration
# =============================================================================

# Path to your library root directory
# This is the directory containing all your documents, images, and files
# that Librarian will recursively scan and index.
#
# IMPORTANT: Librarian automatically discovers all files and subfolders.
# There is no collection management, folder picker, or import wizard.
# Automatic ingestion begins immediately after startup.
#
# Examples:
#   Windows:    C:/Users/YourName/Documents
#   Linux:     /mnt/storage
#   NAS:       /mnt/nas/documents
#   Docker:    ./volumes/library (relative to deploy directory)
#
LIBRARY_PATH=./volumes/library
