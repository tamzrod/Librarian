# Librarian Environment Configuration - macOS
#
# Single-library architecture deployment.
# API-First: REST API is the primary interface.
# GUI is optional and communicates via API only.

# =============================================================================
# PostgreSQL Configuration
# =============================================================================

POSTGRES_DB=librarian
POSTGRES_USER=librarian
POSTGRES_PASSWORD=librarian
POSTGRES_PORT=5432

# =============================================================================
# API Configuration
# =============================================================================

API_PORT=8000

# =============================================================================
# Library Configuration
# =============================================================================

# Path to your library root directory
# Librarian automatically discovers all files and subfolders recursively.
# No collection management, folder picker, or import wizard.
# Automatic ingestion begins immediately after startup.
#
# Examples:
#   /Users/user/Documents
#   /Users/user/Dropbox
#   /Volumes/External/Library

LIBRARY_PATH=./volumes/library
